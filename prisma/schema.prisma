generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model GeneratedToken {
  id                    Int       @id @default(autoincrement())
  shop                  String
  tokenName             String
  delegateAccessTokenId String    @unique
  delegateAccessToken   String
  accessToken           String
  scopes                String
  createdAt             DateTime  @default(now())
  expiresAt             DateTime?
  lastUsed              DateTime?
  isActive              Boolean   @default(true)
  createdBy             String?
  isPaid                Boolean   @default(false)
  chargeId              String?   @unique

  @@index([shop])
  @@index([isActive])
  @@index([isPaid])
}

model StorefrontToken {
  id                    Int       @id @default(autoincrement())
  shop                  String
  tokenName             String
  delegateAccessTokenId String    @unique
  delegateAccessToken   String
  accessToken           String
  scopes                String
  createdAt             DateTime  @default(now())
  expiresAt             DateTime?
  lastUsed              DateTime?
  isActive              Boolean   @default(true)
  createdBy             String?
  isPaid                Boolean   @default(false)
  chargeId              String?

  @@index([shop])
  @@index([isActive])
  @@index([isPaid])
}

model PaymentCharge {
  id              Int       @id @default(autoincrement())
  chargeId        String    @unique
  tokenId         Int?
  tokenType       String
  shop            String
  amount          String
  status          String    @default("pending")
  confirmationUrl String?
  createdAt       DateTime  @default(now())
  approvedAt      DateTime?

  @@index([chargeId])
  @@index([shop])
  @@index([status])
}
