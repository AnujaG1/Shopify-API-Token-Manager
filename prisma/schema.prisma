// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Model to track generated API tokens 
// Creates a new database table called GeneratedToken
// @id: Marks this as the primary key
 // @default(now()): Automatically sets to current time

model GeneratedToken {
  id                     Int       @id @default(autoincrement())
  shop                   String
  tokenName              String
  delegateAccessTokenId  String    @unique
  delegateAccessToken    String
  accessToken            String
  scopes                 String
  createdAt              DateTime  @default(now())
  expiresAt              DateTime?
  lastUsed               DateTime?
  isActive               Boolean   @default(true)
  createdBy              String?
  isPaid                 Boolean   @default(false)
  chargeId               String?   @unique

  @@index([shop])
  @@index([isActive])
  @@index([isPaid])
}

model StorefrontToken {
  id                     Int       @id @default(autoincrement())
  shop                   String
  tokenName              String
  delegateAccessTokenId  String    @unique
  delegateAccessToken    String
  accessToken            String
  scopes                 String
  createdAt              DateTime  @default(now())
  expiresAt              DateTime?
  lastUsed               DateTime?
  isActive               Boolean   @default(true)
  createdBy              String?
  isPaid                 Boolean   @default(false)
  chargeId               String?   @unique

  @@index([shop])
  @@index([isActive])
  @@index([isPaid])
}

model PaymentCharge {
  id                Int       @id @default(autoincrement())
  chargeId          String    @unique  
  tokenId           Int?       
  tokenType         String    
  shop              String
  amount            String
  status            String    @default("pending")  
  confirmationUrl   String?
  createdAt         DateTime  @default(now())
  approvedAt        DateTime?
  
  @@index([chargeId])
  @@index([shop])
  @@index([status])
}